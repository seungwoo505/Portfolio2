NODE_ENV=development
PORT=3001
TRUST_PROXY=0
REQUEST_TIMEOUT=3000
LOG_LEVEL=info
ENABLE_VERBOSE_LOGS=false
SLOW_REQUEST_MS=1000
PUBLIC_CACHE_TTL_SECONDS=300
PUBLIC_HTTP_MAX_AGE_SECONDS=60
PUBLIC_HTTP_STALE_SECONDS=300
CONTACT_RATE_LIMIT_MAX=5
CONTACT_RECENT_WINDOW_HOURS=1
CONTACT_RECENT_IP_MAX=3

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_SCHEMA=portfolio_db
# 콘텐츠 이전 시 기존 DB와 신규 DB를 분리해서 지정합니다.
SOURCE_DB_SCHEMA=portfolio_db_old
TARGET_DB_SCHEMA=portfolio_db

JWT_SECRET=change_me_to_a_long_random_secret
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change_me_before_migration
ADMIN_BOOTSTRAP_FULL_NAME=Super Admin

LOCALHOST=http://localhost:3000
MY_HOST=https://example.com

# 개발 환경에서는 비워두면 HTTP로 실행됩니다.
# 운영 환경에서는 HTTPS_KEY와 HTTPS_CERT가 필요합니다.
HTTPS_KEY=/path/to/private.key
HTTPS_CERT=/path/to/certificate.crt
# 중간 인증서가 필요한 경우에만 설정합니다.
HTTPS_CA=/path/to/ca-bundle.crt

REDIS_SOCKET=/run/synocached.sock
GEMINI_API_KEY=
