{
  "name": "portfolio-blog-server",
  "version": "1.0.0",
  "description": "Portfolio blog server with REST API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "setup:db": "node scripts/setup-database.js",
    "migrate": "node scripts/setup-database.js",
    "migrate:content": "node migrations/content-migration.js",
    "migrate:ip": "node scripts/run-ip-useragent-migration.js",
    "sessions:cleanup": "node scripts/cleanup-admin-sessions.js",
    "check": "node scripts/check.js",
    "check:mcp": "npm --prefix mcp run smoke",
    "test:unit": "node --test tests/*.test.js",
    "test": "npm run check && npm run test:unit"
  },
  "keywords": [
    "blog",
    "portfolio",
    "express",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-ws": "^5.0.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.7.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "mysql2": "^3.6.5",
    "node-cache": "^5.1.2",
    "redis": "^5.8.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
